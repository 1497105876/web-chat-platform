# 服务端口
PORT=3000

# MySQL 数据库连接
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=chat_app

# 消息历史加载条数
MESSAGE_HISTORY_LIMIT=50

# 消息发送频率限制（毫秒）
MESSAGE_RATE_LIMIT_MS=1000

# WebSocket 允许的来源（* 表示全部允许）
ALLOWED_ORIGINS=*

# JWT 密钥（生产环境务必更换）
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 文件上传配置
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp
